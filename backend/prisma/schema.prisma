// =====================================================================
// Smart Anti-Theft Recovery System — Prisma schema (Sprint 1)
// =====================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries go through the Supabase transaction pooler (PgBouncer).
  url       = env("DATABASE_URL")
  // Migrations need a direct (unpooled) session — Prisma uses this for
  // `migrate`, `db push`, and introspection.
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
}

enum DeviceStatus {
  ACTIVE
  LOST
  RECOVERED
  DISABLED
}

enum PhotoTrigger {
  SIM_REPLACEMENT
  REMOTE_COMMAND
  UNLOCK_FAILURE
  MANUAL
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(190)
  phone        String?   @unique @db.VarChar(32)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  fullName     String    @map("full_name") @db.VarChar(120)
  role         UserRole  @default(OWNER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  devices  Device[]
  sessions Session[]

  @@index([email])
  @@map("users")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  deviceId  String?   @map("device_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Device {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  deviceUid    String       @unique @map("device_uid") @db.VarChar(190)
  label        String       @db.VarChar(120)
  manufacturer String?      @db.VarChar(80)
  model        String?      @db.VarChar(80)
  osVersion    String?      @map("os_version") @db.VarChar(40)
  appVersion   String?      @map("app_version") @db.VarChar(20)
  simSerial    String?      @map("sim_serial") @db.VarChar(40)
  simOperator  String?      @map("sim_operator") @db.VarChar(60)
  pushToken    String?      @map("push_token") @db.VarChar(255)
  status       DeviceStatus @default(ACTIVE)
  lastSeenAt   DateTime?    @map("last_seen_at") @db.Timestamptz()
  enrolledAt   DateTime     @default(now()) @map("enrolled_at") @db.Timestamptz()
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions   Session[]
  locations  Location[]
  simChanges SimChange[]
  photos     Photo[]

  @@index([userId])
  @@index([status])
  @@index([lastSeenAt])
  @@map("devices")
}

model Location {
  id            String   @id @default(uuid()) @db.Uuid
  deviceId      String   @map("device_id") @db.Uuid
  clientEventId String?  @map("client_event_id") @db.VarChar(36)
  latitude      Float
  longitude     Float
  accuracy      Float?
  altitude      Float?
  speed         Float?
  heading       Float?
  recordedAt    DateTime @map("recorded_at") @db.Timestamptz()
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, clientEventId])
  @@index([deviceId, recordedAt])
  @@map("locations")
}

model SimChange {
  id                String   @id @default(uuid()) @db.Uuid
  deviceId          String   @map("device_id") @db.Uuid
  clientEventId     String?  @map("client_event_id") @db.VarChar(36)
  previousSerial    String?  @map("previous_serial") @db.VarChar(40)
  newSerial         String?  @map("new_serial") @db.VarChar(40)
  previousOperator  String?  @map("previous_operator") @db.VarChar(60)
  newOperator       String?  @map("new_operator") @db.VarChar(60)
  detectedAt        DateTime @map("detected_at") @db.Timestamptz()
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, clientEventId])
  @@index([deviceId, detectedAt])
  @@map("sim_changes")
}

model Photo {
  id            String       @id @default(uuid()) @db.Uuid
  deviceId      String       @map("device_id") @db.Uuid
  clientEventId String?      @map("client_event_id") @db.VarChar(36)
  trigger       PhotoTrigger
  storagePath   String       @map("storage_path") @db.VarChar(500)
  mimeType      String       @map("mime_type") @db.VarChar(64)
  fileSize      Int          @map("file_size")
  capturedAt    DateTime     @map("captured_at") @db.Timestamptz()
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, clientEventId])
  @@index([deviceId, capturedAt])
  @@map("photos")
}
